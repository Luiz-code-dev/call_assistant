# URL do backend Spring Boot
BACKEND_URL=http://localhost:8080

# JWT Secret (gere uma string aleatória forte)
JWT_SECRET=sua-chave-secreta-aqui

# Stripe — chaves de API
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe — price IDs dos planos (criar no Dashboard do Stripe em USD)
# Basic: $15/mo — 500 credits
NEXT_PUBLIC_STRIPE_PRICE_BASIC=price_...
# Premium: $30/mo — 1000 credits
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM=price_...

# Stripe — price IDs dos top-ups de créditos (one-time, USD)
NEXT_PUBLIC_STRIPE_PRICE_CREDITS_5=price_...
NEXT_PUBLIC_STRIPE_PRICE_CREDITS_10=price_...
NEXT_PUBLIC_STRIPE_PRICE_CREDITS_25=price_...
NEXT_PUBLIC_STRIPE_PRICE_CREDITS_50=price_...

# URL pública do site (usado em redirects do Stripe)
NEXT_PUBLIC_APP_URL=http://localhost:3000
