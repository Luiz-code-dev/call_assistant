{
  "name": "@call-assistant/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "electron-vite build",
    "pack": "electron-vite build && electron-builder --win --publish never",
    "preview": "electron-vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "clean": "rimraf out dist-electron"
  },
  "dependencies": {
    "@call-assistant/shared-types": "workspace:*",
    "electron-updater": "^6.3.9",
    "fs-extra": "^11.3.4"
  },
  "build": {
    "appId": "com.callassistant",
    "productName": "Call Assistant",
    "copyright": "Copyright © 2025 Luiz Eduardo da Silva Dias Melo",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "../../services/audio-engine/target/release/audio-engine.exe",
        "to": "sidecar/audio-engine.exe"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "Luiz-code-dev",
      "repo": "call_assistant"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "CallAssistant-Setup-${version}.exe"
    },
    "nsis": {
      "oneClick": false,
      "unicode": true,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Call Assistant",
      "installerIcon": null,
      "deleteAppDataOnUninstall": true,
      "license": "resources/license.txt"
    }
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^2.0.0",
    "@electron-toolkit/eslint-config-ts": "^2.0.0",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@tailwindcss/typography": "^0.5.15",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^33.3.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^3.0.0",
    "eslint": "^8.57.0",
    "ky": "^1.7.2",
    "lucide-react": "^0.468.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^6.0.0",
    "tailwind-merge": "^2.5.5",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.0",
    "vite": "^5.4.0",
    "zustand": "^5.0.2"
  }
}
