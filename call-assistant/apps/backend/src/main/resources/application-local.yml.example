# Template de configuração local — COMMITAR este arquivo.
# Copie para application-local.yml e preencha os valores reais.
# O arquivo application-local.yml NÃO deve ser commitado.

callassistant:
  ai:
    openai:
      api-key: COLOQUE_SUA_OPENAI_API_KEY_AQUI
      copilot-prompt-id: COLOQUE_SEU_PROMPT_ID_AQUI
      copilot-prompt-version: "1"
  wallet:
    web-app-url: http://localhost:3000
    internal-secret: MESMO_VALOR_QUE_INTERNAL_API_SECRET_NO_NEXTJS
